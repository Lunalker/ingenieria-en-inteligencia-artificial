# === Credenciales obligatorias ===
# IMPORTANTE: Debe ser un Classic PAT (ghp_...), NO fine-grained.
# Crear en: https://github.com/settings/tokens -> Generate new token (Classic)
# Sin scopes necesarios, solo debe tener permisos de models.
# Luego aceptar términos en: https://github.com/marketplace/models
GITHUB_TOKEN=tu_token_aqui

# === Credenciales opcionales (para envio de emails) ===
CONFIG_EMAIL_REMITENTE=tu_correo@gmail.com
CONFIG_EMAIL_PASSWORD=tu_contraseña_de_app

# === URLs (no modificar) ===
OPENAI_BASE_URL=https://models.inference.ai.azure.com
GITHUB_BASE_URL=https://models.inference.ai.azure.com
OPENAI_EMBEDDINGS_URL=https://models.github.ai/inference
