# IMPORTANTE: Nunca subas el archivo .env al repositorio

# --- GitHub Models API ---
# URLs base para acceder a los modelos de GitHub (no modificar)
OPENAI_BASE_URL="https://models.inference.ai.azure.com"
GITHUB_BASE_URL="https://models.inference.ai.azure.com"
OPENAI_EMBEDDINGS_URL="https://models.github.ai/inference"

# Tu token personal de GitHub con acceso a GitHub Models
# Obtener en: https://github.com/settings/tokens
